# ---------------------------------------------------------------------------
# PartSelect Chat Agent — backend environment
#
# Copy this file to backend/.env and fill in the values marked REQUIRED.
# Anything left blank uses the default shown in the comment.
# ---------------------------------------------------------------------------

# ===== LLM providers ========================================================
# At least ONE of these must be set. The orchestrator and validator default
# providers (below) determine which key is mandatory.
#
# For the cheapest path that runs all 12 Phase 1 eval cases end to end,
# set only GROQ_API_KEY (free) and switch the orchestrator default to groq.
#
# Get keys:
#   Anthropic:  https://console.anthropic.com/  (Claude)
#   OpenAI:     https://platform.openai.com/    (GPT-4o, validator)
#   Groq:       https://console.groq.com/       (Llama 3.x, free tier)

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# ===== Role defaults ========================================================
# Per-request X-LLM-Provider and X-LLM-Model headers override these.
# The frontend ProviderSwitcher in the header writes the provider header
# automatically.

LLM_ORCHESTRATOR_PROVIDER=anthropic
LLM_ORCHESTRATOR_MODEL=claude-sonnet-4-6

LLM_VALIDATOR_PROVIDER=openai
LLM_VALIDATOR_MODEL=gpt-4o

LLM_UTILITY_PROVIDER=groq
LLM_UTILITY_MODEL=llama-3.1-8b-instant

# ===== Embeddings + reranker (Phase 2 retrieval) ===========================
# Local sentence-transformers / cross-encoder by default; no API key needed.
# Models download on first use.

EMBEDDINGS_PROVIDER=local
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ===== Storage ==============================================================
# DATABASE_URL is REQUIRED. Recommended: a free Supabase project.
#   1. Sign up at https://supabase.com/
#   2. New project (free tier is fine).
#   3. Settings -> Database -> Connection string -> URI (the "direct" one,
#      not the pooler URL).
#   4. Paste it here. The connection string includes the password.
#
# Local Postgres also works:
#   postgresql://USER:PASS@localhost:5432/DBNAME

DATABASE_URL=postgresql://partselect:partselect@localhost:5432/partselect

# KG snapshot path (relative to backend/). Auto-built by scripts/build_kg.py.
KG_PATH=./data/kg.json

# Chroma local persist dir (relative to backend/). Used in Phase 2.
CHROMA_PATH=./data/chroma

# ===== Server ===============================================================
# Comma-separated list of allowed CORS origins. Add additional origins if
# you run the frontend on a non-default host or port.

CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
