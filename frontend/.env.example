# Frontend environment.
#
# Local dev: copy to .env.local and adjust as needed. Defaults below point
# at the backend running on http://localhost:8000.
#
# Vercel deploy: set NEXT_PUBLIC_BACKEND_URL in the Vercel project settings
# (Project -> Settings -> Environment Variables) to the public Fly.io URL,
# e.g. https://partselect-chat-api.fly.dev. The NEXT_PUBLIC_ prefix is
# required because the chat hook reads it in the browser.

NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Server-side proxy target for the /api/health route (NOT exposed to the
# browser). Usually mirrors NEXT_PUBLIC_BACKEND_URL but can differ if you
# want to reach the backend via a private network from the Vercel runtime.
BACKEND_URL=http://localhost:8000
